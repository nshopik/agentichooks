{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "Agentic Hooks",
  "Version": "0.9.1.0",
  "Author": "Nikolay Shopik",
  "Category": "Agentic Hooks",
  "CategoryIcon": "images/actions/category",
  "Description": "Stream Deck plugin that flashes a button on agent hook events. Works with Anthropic Claude Code: shows a visible (and optional audible) alert when a turn ends, a permission is requested, or a task completes. Local Windows/macOS and remote sessions over SSH.",
  "URL": "https://github.com/nshopik/agentichooks",
  "Icon": "images/plugin-icon",
  "CodePath": "bin/plugin.js",
  "UUID": "com.nshopik.agentichooks",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Nodejs": {
    "Version": "24"
  },
  "Actions": [
    {
      "Name": "On Stop",
      "UUID": "com.nshopik.agentichooks.stop",
      "Icon": "images/actions/stop",
      "Controllers": ["Keypad"],
      "Tooltip": "Flash on a Claude Code Stop hook",
      "PropertyInspectorPath": "ui/flash.html",
      "SupportedInMultiActions": false,
      "DisableAutomaticStates": true,
      "States": [
        { "Image": "images/keys/stop-idle",  "Name": "Idle"  },
        { "Image": "images/keys/stop-alert", "Name": "Alert" }
      ]
    },
    {
      "Name": "On Permission",
      "UUID": "com.nshopik.agentichooks.permission",
      "Icon": "images/actions/permission",
      "Controllers": ["Keypad"],
      "Tooltip": "Flash on a Claude Code Permission Request hook",
      "PropertyInspectorPath": "ui/flash.html",
      "SupportedInMultiActions": false,
      "DisableAutomaticStates": true,
      "States": [
        { "Image": "images/keys/permission-idle",  "Name": "Idle"  },
        { "Image": "images/keys/permission-alert", "Name": "Alert" }
      ]
    },
    {
      "Name": "On Task Completed",
      "UUID": "com.nshopik.agentichooks.task-completed",
      "Icon": "images/actions/task-completed",
      "Controllers": ["Keypad"],
      "Tooltip": "Flash on a Claude Code Task Completed hook",
      "PropertyInspectorPath": "ui/flash.html",
      "SupportedInMultiActions": false,
      "DisableAutomaticStates": true,
      "States": [
        { "Image": "images/keys/task-completed-idle",  "Name": "Idle"  },
        { "Image": "images/keys/task-completed-alert", "Name": "Alert" }
      ]
    }
  ]
}

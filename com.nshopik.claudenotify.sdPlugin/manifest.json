{
  "Name": "Agent Hook Notify",
  "Version": "1.0.0.0",
  "Author": "Nikolay Shopik",
  "Category": "Agent Hook Notify",
  "CategoryIcon": "images/actions/category",
  "Description": "Flashes a Stream Deck button on agent hook events. Works with Anthropic Claude Code: shows a visible (and optional audible) alert when a turn ends, a permission is requested, or a task completes. Local Windows/macOS and remote sessions over SSH.",
  "URL": "https://github.com/nshopik/claudenotify",
  "Icon": "images/plugin-icon",
  "CodePath": "bin/plugin.js",
  "UUID": "com.nshopik.claudenotify",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Nodejs": {
    "Version": "24"
  },
  "Actions": [
    {
      "Name": "Flash",
      "UUID": "com.nshopik.claudenotify.flash",
      "Icon": "images/actions/flash",
      "Tooltip": "Flash on a Claude Code hook event",
      "PropertyInspectorPath": "ui/flash.html",
      "SupportedInMultiActions": false,
      "DisableAutomaticStates": true,
      "States": [
        {
          "Image": "images/keys/stop-idle",
          "Name": "Idle"
        },
        {
          "Image": "images/keys/stop-alert",
          "Name": "Alert"
        }
      ]
    }
  ]
}